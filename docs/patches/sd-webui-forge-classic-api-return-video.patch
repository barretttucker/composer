+def encode_processed_video_for_api(processed, send_images: bool) -> str | None:
+    """WAN / video pipelines set Processed.video_path to an on-disk MP4 or MKV; API clients need the bytes."""
+    if not send_images:
+        return None
+    vp = getattr(processed, "video_path", None)
+    if not vp or not os.path.isfile(vp):
+        return None
+    with open(vp, "rb") as f:
+        return base64.b64encode(f.read()).decode("ascii")
+
