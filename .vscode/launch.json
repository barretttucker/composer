{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: dev (debug)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      "args": ["dev", "--turbopack"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "noDebug": false
    },
    {
      "name": "Next.js: dev (no debugger)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      "args": ["dev", "--turbopack"],
      "console": "integratedTerminal",
      "noDebug": true
    },
    {
      "name": "Next.js: dev (verbose — Forge raw HTTP)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      "args": ["dev", "--turbopack"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "noDebug": true,
      "env": {
        "COMPOSER_FORGE_RAW_HTTP": "1"
      }
    },
    {
      "name": "Next.js: dev (verbose — Forge raw HTTP, debug)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      "args": ["dev", "--turbopack"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "noDebug": false,
      "env": {
        "COMPOSER_FORGE_RAW_HTTP": "1"
      }
    }
  ]
}
